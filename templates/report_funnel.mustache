{{!
    @template mod_stackmastery/report_funnel

    The cohort funnel and stat cards at the top of the report overview.

    Context variables required for this template:
    * cards - array of { label, value, sub } where sub is optional secondary text

    Example context (json):
    {
        "cards": [
            {"label": "Started", "value": "12", "sub": ""},
            {"label": "Reached the target", "value": "9", "sub": "75% of started"}
        ]
    }
}}
<div class="stackmastery-funnel d-flex flex-wrap mb-3">
    {{#cards}}
        <div class="card mr-2 mb-2 stackmastery-funnel-card">
            <div class="card-body p-3">
                <div class="h4 mb-0">{{value}}</div>
                <div class="text-muted small">{{label}}</div>
                {{#sub}}
                    <div class="text-muted small">{{sub}}</div>
                {{/sub}}
            </div>
        </div>
    {{/cards}}
</div>
