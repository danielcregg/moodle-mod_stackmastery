{{!
    @template mod_stackmastery/progress_bars

    Accessible per-skill mastery bars with an optional target line.

    Accessibility contract (normative): each bar is role="progressbar" with aria-valuemin/max/now,
    labelled by the skill name and described by the visible value cell; the target line itself is
    aria-hidden and its meaning is carried by the visible target note; the reached state is colour
    AND a check glyph AND screen-reader text, never colour alone.

    Context variables required for this template:
    * heading - string, accessible name of the region
    * showtarget - bool, whether to render the target note and line
    * targetpercent - int, 0..100
    * skills - array of rows { code, name, percent, percentlabel, reached }

    Example context (json):
    {
        "heading": "Your mastery",
        "showtarget": true,
        "targetpercent": 95,
        "skills": [
            {
                "code": "differentiate",
                "name": "Differentiation",
                "percent": 62,
                "percentlabel": "62%",
                "reached": false
            }
        ]
    }
}}
<section class="stackmastery-progress" aria-label="{{heading}}">
    <h3 class="h6">{{heading}}</h3>
    {{#showtarget}}
        <p class="stackmastery-progress-targetnote">{{#str}} targetnote, mod_stackmastery, {{targetpercent}} {{/str}}</p>
    {{/showtarget}}
    {{#skills}}
        <div class="stackmastery-progress-row">
            <span class="stackmastery-progress-skill" id="sm-lbl-{{code}}-{{uniqid}}">{{name}}</span>
            <div class="stackmastery-progress-track"
                 role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{percent}}"
                 aria-labelledby="sm-lbl-{{code}}-{{uniqid}}" aria-describedby="sm-val-{{code}}-{{uniqid}}">
                <div class="stackmastery-progress-fill {{#reached}}stackmastery-reached{{/reached}}"
                     style="width: {{percent}}%"></div>
                {{#showtarget}}
                    <div class="stackmastery-target-line" style="inset-inline-start: {{targetpercent}}%" aria-hidden="true"></div>
                {{/showtarget}}
            </div>
            <span class="stackmastery-progress-value" id="sm-val-{{code}}-{{uniqid}}">
                {{percentlabel}}{{#reached}}
                    <span class="stackmastery-reached-check" aria-hidden="true">&#10003;</span>
                    <span class="sr-only">{{#str}} targetreached, mod_stackmastery {{/str}}</span>
                {{/reached}}
            </span>
        </div>
    {{/skills}}
</section>
