{{!
    @template mod_stackmastery/attempt_page

    The attempt page: notice banners, the review panel of the just-graded question, the mastery
    progress region, the open question inside its single mutation form, and the End-attempt-now
    escape hatch. The question HTML posts to processattempt.php; the hidden slot field is
    informational only (the server names the slot).

    Context variables required for this template:
    * notices - array of { message, type } alert banners
    * hasreview / reviewheading / reviewbannertype / reviewbanner / reviewhtml - review panel
    * hasprogress / progress - bool / progress_bars context
    * skillsattarget - string, shown with the progress region
    * questionprogress - string, question n of up to B
    * hasquestion / questionheading / skillchip / questionhtml - the open question
    * noquestion / continueurl - recovery block when no question could be rendered
    * actionurl - processattempt.php URL
    * cmid - int
    * slot - int, informational
    * sesskey - string

    Example context (json):
    {
        "notices": [{"message": "Your attempt was recovered.", "type": "info"}],
        "hasreview": true,
        "reviewheading": "Question 1",
        "reviewbannertype": "success",
        "reviewbanner": "Correct. Your mastery in Differentiation moved from 20% to 61%.",
        "reviewhtml": "<div>question review html</div>",
        "hasprogress": true,
        "progress": {
            "heading": "Your mastery",
            "showtarget": true,
            "targetpercent": 85,
            "skills": [
                {
                    "code": "differentiate",
                    "name": "Differentiation",
                    "percent": 61,
                    "percentlabel": "61%",
                    "reached": false
                }
            ]
        },
        "skillsattarget": "Skills at target: 0 of 1",
        "questionprogress": "Question 2 of up to 5",
        "hasquestion": true,
        "questionheading": "Question 2",
        "skillchip": "Skill: Differentiation",
        "questionhtml": "<div>question html</div>",
        "noquestion": false,
        "continueurl": "https://example.com/mod/stackmastery/attempt.php?id=12",
        "actionurl": "https://example.com/mod/stackmastery/processattempt.php",
        "cmid": 12,
        "slot": 2,
        "sesskey": "abc123"
    }
}}
<div class="stackmastery-attempt" data-region="stackmastery-attempt">

    {{#notices}}
        <div class="alert alert-{{type}}" role="alert">{{message}}</div>
    {{/notices}}

    {{#hasreview}}
        <section class="stackmastery-review mb-3" aria-label="{{reviewheading}}">
            {{#reviewbanner}}
                <div class="stackmastery-outcome alert alert-{{reviewbannertype}}" role="status">{{reviewbanner}}</div>
            {{/reviewbanner}}
            <h3 class="h5">{{reviewheading}}</h3>
            <div class="stackmastery-reviewquestion">{{{reviewhtml}}}</div>
        </section>
    {{/hasreview}}

    {{#hasprogress}}
        {{#progress}}
            {{> mod_stackmastery/progress_bars }}
        {{/progress}}
        <p class="stackmastery-skillsattarget">{{skillsattarget}}</p>
    {{/hasprogress}}

    {{#questionprogress}}
        <p class="stackmastery-questionprogress">{{questionprogress}}</p>
    {{/questionprogress}}

    {{#hasquestion}}
        <h3 class="h5">{{questionheading}}</h3>
        {{#skillchip}}
            <p class="mb-2"><span class="stackmastery-skill-chip badge badge-secondary bg-secondary">{{skillchip}}</span></p>
        {{/skillchip}}
        <form method="post" action="{{actionurl}}" id="stackmastery-attemptform" autocomplete="off">
            <input type="hidden" name="id" value="{{cmid}}">
            <input type="hidden" name="action" value="submit">
            <input type="hidden" name="slot" value="{{slot}}">
            <input type="hidden" name="sesskey" value="{{sesskey}}">
            {{{questionhtml}}}
        </form>
    {{/hasquestion}}

    {{#noquestion}}
        <p>
            <a href="{{continueurl}}" class="btn btn-primary">{{#str}} continueattempt, mod_stackmastery {{/str}}</a>
        </p>
    {{/noquestion}}

    <div class="stackmastery-attempt-actions mt-3">
        <form method="post" action="{{actionurl}}" class="stackmastery-endform">
            <input type="hidden" name="id" value="{{cmid}}">
            <input type="hidden" name="action" value="finish">
            <input type="hidden" name="sesskey" value="{{sesskey}}">
            <button type="submit" class="btn btn-secondary">{{#str}} endattempt, mod_stackmastery {{/str}}</button>
        </form>
        <p class="text-muted small mt-2">{{#str}} leavenote, mod_stackmastery {{/str}}</p>
    </div>
</div>
