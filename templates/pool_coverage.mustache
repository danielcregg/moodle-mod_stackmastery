{{!
    @template mod_stackmastery/pool_coverage

    Question counts per (skill, difficulty) cell of the pool: red badge for empty cells,
    amber for thin (1 or 2) cells.

    Context variables required for this template:
    * difficulties - array of { label }
    * skills - array of { name, cells: array of { count, empty, thin } }

    Example context (json):
    {
        "difficulties": [
            {"label": "Easy"},
            {"label": "Medium"},
            {"label": "Hard"}
        ],
        "skills": [
            {
                "name": "Differentiation",
                "cells": [
                    {"count": 3, "empty": false, "thin": false},
                    {"count": 1, "empty": false, "thin": true},
                    {"count": 0, "empty": true, "thin": false}
                ]
            }
        ]
    }
}}
<div class="stackmastery-coverage table-responsive">
    <table class="generaltable stackmastery-coverage-table">
        <thead>
            <tr>
                <th scope="col">{{#str}} colskill, mod_stackmastery {{/str}}</th>
                {{#difficulties}}
                    <th scope="col">{{label}}</th>
                {{/difficulties}}
            </tr>
        </thead>
        <tbody>
            {{#skills}}
                <tr>
                    <th scope="row">{{name}}</th>
                    {{#cells}}
                        <td>
                            <span class="badge {{#empty}}badge-danger bg-danger{{/empty}}{{#thin}}badge-warning bg-warning{{/thin}}{{^empty}}{{^thin}}badge-secondary bg-secondary{{/thin}}{{/empty}}">{{count}}</span>
                        </td>
                    {{/cells}}
                </tr>
            {{/skills}}
        </tbody>
    </table>
</div>
